{
  "name": "language-player",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck",
    "typecheck:watch": "tsc --watch --noEmit --project apps/web/tsconfig.json",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/spark-md5": "^3.0.5",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "packageManager": "npm@10.7.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "spark-md5": "^3.0.2"
  }
}
