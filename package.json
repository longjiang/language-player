{
  "name": "language-player",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck",
    "typecheck:watch": "tsc --watch --noEmit --project apps/web/tsconfig.json"
  },
  "devDependencies": {
    "@types/spark-md5": "^3.0.5",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "npm@10.7.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "spark-md5": "^3.0.2"
  }
}
