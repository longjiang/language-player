# Directus 8 API (auth + CMS) — the path prefix /zerotohero is part of the base URL
NEXT_PUBLIC_DIRECTUS_URL=https://directusvps.zerotohero.ca/zerotohero

# Python backend (payments, NLP, email verification, video recommendations)
# Use https://pythonvps.zerotohero.ca for production, http://localhost:5001 for local dev
NEXT_PUBLIC_API_URL=http://localhost:5001

# NextAuth v5 (Auth.js) — note: v5 uses AUTH_ prefix, not NEXTAUTH_
AUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
